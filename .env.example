# ═══════════════════════════════════════════════════════════════
# GentsStyling — WhatsApp AI Agent
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Meta / WhatsApp Cloud API ───────────────────────────────────
# Get from: developers.facebook.com → Your App → WhatsApp → API Setup
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=gents_styling_secret_2024
WHATSAPP_APP_SECRET=

# ── OpenAI ──────────────────────────────────────────────────────
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Supabase ────────────────────────────────────────────────────
# Get from: supabase.com/dashboard → Project → Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Server ──────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Public URL ──────────────────────────────────────────────────
# Dev:  your ngrok URL   e.g. https://xxxx.ngrok-free.app
# Prod: your Railway/VPS domain e.g. https://yourdomain.com
PUBLIC_URL=https://your-ngrok-url.ngrok-free.app

# ── Business Info ────────────────────────────────────────────────
BUSINESS_NAME=GentsStyling
BUSINESS_WHATSAPP_NUMBER=+15556493086
BUSINESS_WEBSITE=https://gentsstyling.com
